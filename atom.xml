    <title>差分约束系统</title>
    <link href="https://robin2333.github.io/2018/07/30/%E5%9B%BE%E8%AE%BA/%E5%B7%AE%E5%88%86%E7%BA%A6%E6%9D%9F%E7%B3%BB%E7%BB%9F/"/>
